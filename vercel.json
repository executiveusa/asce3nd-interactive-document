{
  "version": 2,
  "rewrites": [
    { "source": "/event/community-cuts", "destination": "/public/event/community-cuts.html" },
    { "source": "/event/community-cuts/", "destination": "/public/event/community-cuts.html" },
    { "source": "/((?!api|event|public|images).*)", "destination": "/api/document" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
